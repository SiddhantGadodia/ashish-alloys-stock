generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  password  String
  role      String   // "staff" | "verifier"
  createdAt DateTime @default(now())

  purchaseEntries               PurchaseEntry[]
  internalTransferInstructions  InternalTransfer[]      @relation("ITInstruction")
  internalTransferActuals       InternalTransfer[]      @relation("ITActuals")
  internalTransferVerifications InternalTransfer[]      @relation("ITVerification")
  productionPlannings           ProductionPlanning[] @relation("PPCreated")
  productionActuals             ProductionPlanning[] @relation("PPActuals")
  productionVerifications       ProductionPlanning[] @relation("PPVerification")
  finishedGoodsActuals          FinishedGoodsTransfer[] @relation("FGTActuals")
  finishedGoodsVerifications    FinishedGoodsTransfer[] @relation("FGTVerification")
  salesInstructions             Sale[]                  @relation("SaleInstruction")
  salesActuals                  Sale[]                  @relation("SaleActuals")
  salesVerifications            Sale[]                  @relation("SaleVerification")
  correctionLogs                CorrectionLog[]
}

model DropdownOption {
  id       String  @id @default(cuid())
  field    String
  value    String
  isSystem Boolean @default(false)
  active   Boolean @default(true)

  @@unique([field, value])
}

model StockLot {
  id              String   @id @default(cuid())
  grade           String
  size            String
  supplyCondition String
  make            String
  location        String
  pieces          Int?
  quantity        Float
  length          Float?
  description     String
  uidNo           String?
  subLoc          String?
  jwNo            String?
  remarks         String?
  lineage         String?
  dateCreated     DateTime
  originForm      String
  originId        String
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SuspenseTotal {
  id       String @id @default(cuid())
  location String @unique
  total    Float  @default(0)
}

model CorrectionLog {
  id            String   @id @default(cuid())
  tableRef      String
  recordId      String
  field         String
  oldValue      String?
  newValue      String?
  action        String
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  performedAt   DateTime @default(now())
}

model PurchaseEntry {
  id              String   @id @default(cuid())
  formNo          Int      @default(autoincrement())
  date            DateTime
  grade           String
  size            String
  supplyCondition String
  pieces          Int?
  make            String
  quantity        Float
  length          Float?
  description     String
  location        String
  uidNo           String?
  subLoc          String?
  remarks         String?
  stockLotId      String?
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Form 1 — Internal Transfer
// instrLotsJson / actLotsJson: JSON string of LotEntry[]
// LotEntry: { lotId, lotSnapshot: {grade,size,supplyCondition,make,description,uidNo,subLoc,pieces,quantity}, detail: {date,qty,locationTo,pieces,uidNo,subLoc,remarks} }
model InternalTransfer {
  id     String @id @default(cuid())
  formNo Int    @default(autoincrement())
  // "instruction" | "actuals_filled" | "verified"
  status String @default("instruction")
  // "instruction" (had instr step) | "direct" (skipped instr)
  entryType String @default("instruction")

  locationFrom    String?
  instrLotsJson   String?
  instructedById  String?
  instructedBy    User?     @relation("ITInstruction", fields: [instructedById], references: [id])
  instructedAt    DateTime?

  actLotsJson       String?
  actualsFilledById String?
  actualsFilledBy   User?     @relation("ITActuals", fields: [actualsFilledById], references: [id])
  actualsFilledAt   DateTime?

  verifiedById  String?
  verifiedBy    User?     @relation("ITVerification", fields: [verifiedById], references: [id])
  verifiedAt    DateTime?

  createdLotIds String?   // JSON array of StockLot ids created on verify
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Form 2 — Production Planning
// instrLotsJson: instruction lot sections
// actLotsJson: actuals lot sections — { lotId, lotSnapshot: {grade,size,supplyCondition,make,description,location,subLoc,quantity}, sections: [{date,machine,sizeFinal,supplyConditionFinal,qty,lengthFinal,remarks}] }
model ProductionPlanning {
  id              String   @id @default(cuid())
  formNo          Int      @default(autoincrement())
  status          String   @default("instruction")   // "instruction" | "actuals_filled" | "verified"
  entryType       String   @default("instruction")   // "instruction" | "direct"
  locationInitial String?
  lotSectionsJson String?  // instruction data (kept for backwards compat)
  actLotsJson     String?  // actuals data

  createdById     String
  createdBy       User     @relation("PPCreated", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  actualsFilledById String?
  actualsFilledBy   User?     @relation("PPActuals", fields: [actualsFilledById], references: [id])
  actualsFilledAt   DateTime?

  verifiedById    String?
  verifiedBy      User?     @relation("PPVerification", fields: [verifiedById], references: [id])
  verifiedAt      DateTime?

  updatedAt       DateTime @updatedAt
}

// Form 3 — Finished Goods Transfer
// lotSectionsJson: JSON string of LotSection[]
// LotSection: { lotId, lotSnapshot: {grade,make,description,uidNo,subLoc,quantity,pieces}, sections: [{date,qty,supplyCondition,sizeFinal,locationFinal,subLocFinal,suspenseQty,pieces,remarks}] }
model FinishedGoodsTransfer {
  id     String @id @default(cuid())
  formNo Int    @default(autoincrement())
  status String @default("actuals_filled") // "actuals_filled" | "verified"

  locationInitial   String?
  lotSectionsJson   String?
  actualsFilledById String?
  actualsFilledBy   User?     @relation("FGTActuals", fields: [actualsFilledById], references: [id])
  actualsFilledAt   DateTime?

  verifiedById String?
  verifiedBy   User?     @relation("FGTVerification", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?

  createdLotIds String?   // JSON array of StockLot ids created on verify
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Form 4 — Sales
// instrLotsJson / actLotsJson: JSON string of LotEntry[]
// LotEntry: { lotId, lotSnapshot: {grade,size,supplyCondition,make,subLoc,uidNo,pieces,quantity}, detail: {customer,qty,vehicleNo,pieces,remarks} }
model Sale {
  id        String @id @default(cuid())
  formNo    Int    @default(autoincrement())
  status    String @default("instruction") // "instruction" | "actuals_filled" | "verified"
  entryType String @default("instruction") // "instruction" | "direct"

  locationFrom    String?
  instrLotsJson   String?
  instructedById  String?
  instructedBy    User?     @relation("SaleInstruction", fields: [instructedById], references: [id])
  instructedAt    DateTime?

  actLotsJson       String?
  actualsFilledById String?
  actualsFilledBy   User?     @relation("SaleActuals", fields: [actualsFilledById], references: [id])
  actualsFilledAt   DateTime?

  verifiedById String?
  verifiedBy   User?     @relation("SaleVerification", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
